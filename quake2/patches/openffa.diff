diff --git a/.config-win32 b/.config-win32
new file mode 100644
index 0000000..f321618
--- /dev/null
+++ b/.config-win32
@@ -0,0 +1,11 @@
+CONFIG_WINDOWS = 1
+CONFIG_32BIT = 1
+
+TARGET = gamex86.dll
+
+CC = i686-w64-mingw32-gcc
+LD = i686-w64-mingw32-gcc
+WINDRES = i686-w64-mingw32-windres
+
+CFLAGS = -std=gnu99 -static -static-libgcc -DCURL_STATICLIB -DHAVE_CURL -DWIN32 -D_WIN32 -D__USE_W32_SOCKETS
+LIBS = -L/usr/i686-w64-mingw32/lib -lcurl -lnghttp2 -lidn2 -lssh2 -lpsl -lbcrypt -ladvapi32 -lcrypt32 -lssl -lcrypto -lwldap32 -lzstd -lbrotlidec -lz -lws2_32
diff --git a/.config-win64 b/.config-win64
new file mode 100644
index 0000000..5641536
--- /dev/null
+++ b/.config-win64
@@ -0,0 +1,11 @@
+CONFIG_WINDOWS = 1
+
+TARGET = gamex86_64.dll
+
+CC = x86_64-w64-mingw32-gcc
+LD = x86_64-w64-mingw32-gcc
+WINDRES = x86_64-w64-mingw32-windres
+
+CFLAGS = -std=gnu99 -static -static-libgcc -DCURL_STATICLIB -DHAVE_CURL -DWIN32 -D_WIN32 -D__USE_W32_SOCKETS
+LIBS = -L/usr/x86_64-w64-mingw32/lib -lcurl -lnghttp2 -lidn2 -lssh2
+
