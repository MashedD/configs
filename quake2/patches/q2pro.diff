+#!/usr/bin/env bash
+set -Eeuo pipefail
+
+meson setup build-win64 \
+    --cross-file cross-mingw64.txt \
+    --buildtype=release \
+    -Ddefault_library=static \
+    -Dc_link_args="-static -static-libgcc" \
+    --force-fallback-for=libcurl,zlib,libjpeg,libpng || :
+meson compile -C build-win64 -j$(nproc)
+chmod -x build-win64/gamex86_64.dll
+
+DEST="../.."
+if [ -e "$DEST/baseq2" ]; then
+    cp -f build-win64/gamex86_64.dll "$DEST/baseq2"
+    cp -f build-win64/q2pro.exe "$DEST"
+    #cp -f build-win64/q2proded.exe "$DEST"
+    cd "$DEST"
+    #./start-q2pro-win64-mashedd.sh
+    wine q2pro.exe +set game opentdm +map q2duel5
+fi
+
