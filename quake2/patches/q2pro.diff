@@ -0,0 +1,23 @@
+#!/usr/bin/env bash
+set -Eeuo pipefail
+
+meson setup build-win32 \
+    --cross-file cross-mingw32.txt \
+    --buildtype=release \
+    -Ddefault_library=static \
+    -Dc_link_args='-static -static-libgcc -D_WIN32_WINNT=0x0501 -DNTDDI_VERSION=0x05010200' \
+    --force-fallback-for=libcurl,zlib,libjpeg,libpng || :
+meson compile -C build-win32
+chmod -x build-win32/gamex86.dll
+
+DEST="../.."
+if [ -e "$DEST/baseq2" ]; then
+    cp -f build-win32/gamex86.dll "$DEST/baseq2"
+    cp -f build-win32/q2pro.exe "$DEST/q2pro32.exe"
+    cp -f "$DEST/q2pro32.exe" "$DEST/q2pro32_winxp.exe" // requires bcrypt.dll
+    #cp -f build-win32/q2proded.exe "$DEST/q2proded32.exe"
+    cd "$DEST"
+    python3 -c 'with open("q2pro32_winxp.exe", "r+b") as f: f.seek(0xC8); f.write(b"\x05")'
+    #./start-q2pro-win32-mashedd.sh
+fi
+
