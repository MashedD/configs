+diff --git a/src/common/cmd.c b/src/common/cmd.c
+index 9ab23baf..c0ec9178 100644
+--- a/src/common/cmd.c
++++ b/src/common/cmd.c
+@@ -45,6 +45,8 @@ cmdbuf_t        cmd_buffer;
+ // points to the buffer current command is executed from
+ cmdbuf_t        *cmd_current;
+ 
++kbutton_t in_drop;
++
+ /*
+ ============
+ Cmd_Wait_f
+@@ -1599,6 +1601,21 @@ void Cmd_ExecuteCommand(cmdbuf_t *buf)
+     }
+ }
+ 
++char* concat(const char *s1, const char *s2)
++{
++    char *result = malloc(strlen(s1) + strlen(s2) + 1); // +1 for the NULL
++    strcpy(result, s1);
++    strcat(result, s2);
++    return result;
++}
++
++bool startsWith(const char *str, const char *start)
++{
++    size_t lenpre = strlen(start),
++        lenstr = strlen(str);
++    return lenstr < lenpre ? false : strncmp(start, str, lenpre) == 0;
++}
++
+ /*
+ ============
+ Cmd_ExecuteString
+@@ -1608,6 +1625,51 @@ A complete command line has been parsed, so try to execute it
+ */
+ void Cmd_ExecuteString(cmdbuf_t *buf, const char *text)
+ {
++    // +dropw command for easy weapon dropping
++    // get first three chars for comparison
++    char dest[4];
++    strncpy(dest, text, 3);
++    dest[3] = 0;
++
++    // if command start with use and in_drop is pressed then we want to drop weapon instead
++    if (!strcmp(dest, "use") && in_drop.state) {
++        // create command name
++        char *cname = malloc(5);
++        memcpy(cname, "drop", 4);
++
++        // concat cname and the rest of the command
++        char *command = concat(cname, text + 3);
++
++        // execute the command like nothing ever happened
++        Cmd_TokenizeString(command, true);
++        Cmd_ExecuteCommand(buf);
++
++        // drop ammo - check what weapon are we using and queue the drop ammo command
++        char leftovers[256];
++        strncpy(leftovers, text + 4, strlen(text + 4)); // copy the leftovers (weapon name)
++
++        if (startsWith(leftovers, "Railgun")) {
++            Cbuf_AddText(buf, "drop slugs");
++        }
++        else if (startsWith(leftovers, "Rocket Launcher")) {
++            Cbuf_AddText(buf, "drop rockets");
++        }
++        else if (startsWith(leftovers, "Shotgun") || startsWith(leftovers, "Super Shotgun")) {
++            Cbuf_AddText(buf, "drop shells");
++        }
++        else if (startsWith(leftovers, "Chaingun") || startsWith(leftovers, "Machinegun")) {
++            Cbuf_AddText(buf, "drop bullets");
++        }
++        else if (startsWith(leftovers, "Hyperblaster") || startsWith(leftovers, "BFG10K")) {
++            Cbuf_AddText(buf, "drop cells");
++        }
++        else if (startsWith(leftovers, "Grenade Launcher")) {
++            Cbuf_AddText(buf, "drop grenades");
++        }
++
++        return;
++    }
++
+     Cmd_TokenizeString(text, true);
+     Cmd_ExecuteCommand(buf);
+ }
+-- 
+2.52.0
+
