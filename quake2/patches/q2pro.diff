+index 3229f721..f2ebabdb 100644
+--- a/README.md
++++ b/README.md
+@@ -30,3 +30,19 @@ BUILDING.md file for instructions.
+ 
+ For information on using and configuring Q2PRO, refer to client and server
+ manuals available in doc/ subdirectory.
++
++## Additional Changes
++
++This source code is based on latest Skullers with added changes made
++by Maciej Szybiak: `https://bitbucket.org/Makowiec/q2pro_m`:
++
++- weapon dropping hotkey +bind_w
++Added weapon use modifier. If key is held and weapon key
++ used it will drop weapons instead of equipping them. Command +dropw Example
++ usage: "bind alt +dropw" - after that alt + R will drop railgun from player's
++ inventory.           
++- ...
++
++set cl_warn_on_fps_rounding 0
++src/common/common.c - change sources link?
++
+diff --git a/inc/common/cmd.h b/inc/common/cmd.h
+index a6b1fc97..c6ce8d75 100644
+--- a/inc/common/cmd.h
++++ b/inc/common/cmd.h
+@@ -209,3 +209,15 @@ int Cmd_ParseOptions(const cmd_option_t *opt);
+ void Cmd_PrintHelp(const cmd_option_t *opt);
+ void Cmd_PrintUsage(const cmd_option_t *opt, const char *suffix);
+ void Cmd_PrintHint(void);
++
++// q2pro_m - move that struct so it can be used in cmd.c
++typedef struct kbutton_s {
++    int         down[2];         // key nums holding it down
++    unsigned    downtime;        // msec timestamp
++    unsigned    msec;            // msec down this frame
++    int         state;
++} kbutton_t;
++
++// q2pro_m - drop command
++extern kbutton_t in_drop;
++
