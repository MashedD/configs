From d2719f9aa41c8453ec6f7da94f2294bb5a4dedf9 Mon Sep 17 00:00:00 2001
From: MashedD <sl8code@gmail.com>
Date: Wed, 4 Feb 2026 10:35:52 +0100
Subject: [PATCH] Add +bindw

---
 README.md                | 16 +++++++++++
 inc/common/cmd.h         | 12 ++++++++
 src/client/input.c       | 20 ++++++++-----
 src/client/ui/q2pro.menu |  1 +
 src/common/cmd.c         | 62 ++++++++++++++++++++++++++++++++++++++++
 5 files changed, 104 insertions(+), 7 deletions(-)

diff --git a/README.md b/README.md
index 3229f721..f2ebabdb 100644
--- a/README.md
+++ b/README.md
@@ -30,3 +30,19 @@ BUILDING.md file for instructions.
 
 For information on using and configuring Q2PRO, refer to client and server
 manuals available in doc/ subdirectory.
+
+## Additional Changes
+
+This source code is based on latest Skullers with added changes made
+by Maciej Szybiak: `https://bitbucket.org/Makowiec/q2pro_m`:
+
+- weapon dropping hotkey +bind_w
+Added weapon use modifier. If key is held and weapon key
+ used it will drop weapons instead of equipping them. Command +dropw Example
+ usage: "bind alt +dropw" - after that alt + R will drop railgun from player's
+ inventory.           
+- ...
+
+set cl_warn_on_fps_rounding 0
+src/common/common.c - change sources link?
+
diff --git a/inc/common/cmd.h b/inc/common/cmd.h
index a6b1fc97..c6ce8d75 100644
--- a/inc/common/cmd.h
+++ b/inc/common/cmd.h
@@ -209,3 +209,15 @@ int Cmd_ParseOptions(const cmd_option_t *opt);
 void Cmd_PrintHelp(const cmd_option_t *opt);
 void Cmd_PrintUsage(const cmd_option_t *opt, const char *suffix);
 void Cmd_PrintHint(void);
+
+// q2pro_m - move that struct so it can be used in cmd.c
+typedef struct kbutton_s {
+    int         down[2];         // key nums holding it down
+    unsigned    downtime;        // msec timestamp
+    unsigned    msec;            // msec down this frame
+    int         state;
+} kbutton_t;
+
+// q2pro_m - drop command
+extern kbutton_t in_drop;
+
diff --git a/src/client/input.c b/src/client/input.c
index a5d14215..bb40723a 100644
--- a/src/client/input.c
+++ b/src/client/input.c
@@ -229,13 +229,6 @@ Key_Event (int key, bool down, unsigned time);
 ===============================================================================
 */
 
-typedef struct {
-    int         down[2];        // key nums holding it down
-    unsigned    downtime;        // msec timestamp
-    unsigned    msec;            // msec down this frame
-    int         state;
-} kbutton_t;
-
 static kbutton_t    in_klook;
 static kbutton_t    in_left, in_right, in_forward, in_back;
 static kbutton_t    in_lookup, in_lookdown, in_moveleft, in_moveright;
@@ -385,6 +378,17 @@ static void IN_UseUp(void)
     KeyUp(&in_use);
 }
 
+static void IN_DropDown(void)
+{
+    KeyDown(&in_drop);
+}
+
+static void IN_DropUp(void)
+{
+    KeyUp(&in_drop);
+    in_drop.state = 0;
+}
+
 static void IN_Impulse(void)
 {
     in_impulse = Q_atoi(Cmd_Argv(1));
@@ -673,6 +677,8 @@ static const cmdreg_t c_input[] = {
     { "-attack", IN_AttackUp },
     { "+use", IN_UseDown },
     { "-use", IN_UseUp },
+    { "+dropw", IN_DropDown },
+    { "-dropw", IN_DropUp },
     { "impulse", IN_Impulse },
     { "+klook", IN_KLookDown },
     { "-klook", IN_KLookUp },
diff --git a/src/client/ui/q2pro.menu b/src/client/ui/q2pro.menu
index e935e8b0..ae372469 100644
--- a/src/client/ui/q2pro.menu
+++ b/src/client/ui/q2pro.menu
@@ -371,4 +371,5 @@ begin weapons
     bind "railgun" "use Railgun"
     bind "bfg10k" "use BFG10K"
     bind "grenades" "use Grenades"
+    bind "drop key" "+dropw"
 end
diff --git a/src/common/cmd.c b/src/common/cmd.c
index 9ab23baf..c0ec9178 100644
--- a/src/common/cmd.c
+++ b/src/common/cmd.c
@@ -45,6 +45,8 @@ cmdbuf_t        cmd_buffer;
 // points to the buffer current command is executed from
 cmdbuf_t        *cmd_current;
 
+kbutton_t in_drop;
+
 /*
 ============
 Cmd_Wait_f
@@ -1599,6 +1601,21 @@ void Cmd_ExecuteCommand(cmdbuf_t *buf)
     }
 }
 
+char* concat(const char *s1, const char *s2)
+{
+    char *result = malloc(strlen(s1) + strlen(s2) + 1); // +1 for the NULL
+    strcpy(result, s1);
+    strcat(result, s2);
+    return result;
+}
+
+bool startsWith(const char *str, const char *start)
+{
+    size_t lenpre = strlen(start),
+        lenstr = strlen(str);
+    return lenstr < lenpre ? false : strncmp(start, str, lenpre) == 0;
+}
+
 /*
 ============
 Cmd_ExecuteString
@@ -1608,6 +1625,51 @@ A complete command line has been parsed, so try to execute it
 */
 void Cmd_ExecuteString(cmdbuf_t *buf, const char *text)
 {
+    // +dropw command for easy weapon dropping
+    // get first three chars for comparison
+    char dest[4];
+    strncpy(dest, text, 3);
+    dest[3] = 0;
+
+    // if command start with use and in_drop is pressed then we want to drop weapon instead
+    if (!strcmp(dest, "use") && in_drop.state) {
+        // create command name
+        char *cname = malloc(5);
+        memcpy(cname, "drop", 4);
+
+        // concat cname and the rest of the command
+        char *command = concat(cname, text + 3);
+
+        // execute the command like nothing ever happened
+        Cmd_TokenizeString(command, true);
+        Cmd_ExecuteCommand(buf);
+
+        // drop ammo - check what weapon are we using and queue the drop ammo command
+        char leftovers[256];
+        strncpy(leftovers, text + 4, strlen(text + 4)); // copy the leftovers (weapon name)
+
+        if (startsWith(leftovers, "Railgun")) {
+            Cbuf_AddText(buf, "drop slugs");
+        }
+        else if (startsWith(leftovers, "Rocket Launcher")) {
+            Cbuf_AddText(buf, "drop rockets");
+        }
+        else if (startsWith(leftovers, "Shotgun") || startsWith(leftovers, "Super Shotgun")) {
+            Cbuf_AddText(buf, "drop shells");
+        }
+        else if (startsWith(leftovers, "Chaingun") || startsWith(leftovers, "Machinegun")) {
+            Cbuf_AddText(buf, "drop bullets");
+        }
+        else if (startsWith(leftovers, "Hyperblaster") || startsWith(leftovers, "BFG10K")) {
+            Cbuf_AddText(buf, "drop cells");
+        }
+        else if (startsWith(leftovers, "Grenade Launcher")) {
+            Cbuf_AddText(buf, "drop grenades");
+        }
+
+        return;
+    }
+
     Cmd_TokenizeString(text, true);
     Cmd_ExecuteCommand(buf);
 }
